  "firestore": {
    "filiais": { "schema": "Filial", "description": "Coleção de filiais cadastrados" },
    "empresas": { "schema": "Empresa", "description": "Coleção de empresas de logística" },
    "entregadores": { "schema": "Entregador", "description": "Coleção de entregadores da frota" },
    "expedicoes": { "schema": "Expedicao", "description": "Lotes de entregas expedidos aos entregadores" },
    "motivos_devolucao": { "schema": "PreSetMotivo", "description": "Motivos padrão customizáveis de devolução" },
    "rotas": { "schema": "Rota", "description": "Rotas cadastradas por filial" },
    "users": { "schema": "User", "description": "Coleção dos usuários de sistema" },
    "estoque": { "schema": "ItemEstoque", "description": "Saldo físico atual de pacotes em custódia na filial" },
    "movimentacoes_estoque": { "schema": "MovimentacaoEstoque", "description": "Histórico de entradas e saídas de pátio" },
    "lixeira": { "schema": "ItemLixeira", "description": "Lixeira unificada para restauração de dados deletados" },
    "vales": { "schema": "Vale", "description": "Vales e despesas pendentes" },
    "recibos_pagamento": { "schema": "ReciboPagamento", "description": "Históricos de fechamento de faturas de entregadores" },
