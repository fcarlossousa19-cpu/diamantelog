{
  "entities": {
    "Filial": {
      "title": "Filial",
      "description": "Filial da distribuidora",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "cnpj": { "type": "string" },
        "cidade": { "type": "string" },
        "estado": { "type": "string" },
        "endereco": { "type": "string" },
        "email": { "type": "string" },
        "contato": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["id", "nome"]
    },
    "Empresa": {
      "title": "Empresa",
      "description": "Empresa embarcadora de pacotes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "cnpj": { "type": "string" },
        "endereco": { "type": "string" },
        "email": { "type": "string" },
        "contato": { "type": "string" },
        "valorPorPacote": { "type": "number" },
        "comissaoEntregador": { "type": "number" },
        "prefixos": { "type": "string" },
        "createdById": { "type": "string" }
      },
      "required": ["id", "nome", "cnpj"]
    },
    "Entregador": {
