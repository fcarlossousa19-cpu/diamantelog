        "filialId": { "type": "string" }
      },
      "required": ["id", "nome", "cpf"]
    },
    "Expedicao": {
      "title": "Expedicao",
      "description": "Lote de expedição para entrega",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entregadorId": { "type": "string" },
        "empresaIds": {
          "type": "array",
