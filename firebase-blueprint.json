        "createdById": { "type": "string" }
      },
      "required": ["id", "nome"]
    },
    "User": {
      "title": "User",
      "description": "Usuário do sistema",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "nomeCompleto": { "type": "string" },
