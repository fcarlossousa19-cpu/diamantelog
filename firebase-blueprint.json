    "transferencias_pacotes": { "schema": "TransferenciaPacote", "description": "Log de transferências entre expedições" },
    "retiradas_pacotes": { "schema": "RetiradaPacote", "description": "Log de devoluções, avarias e outra cidade" }
  }
